generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                String                    @id @default(cuid())
  tenantId          String
  customerId        String?
  productId         String?
  name              String
  currency          String                    @default("MZN")
  status            String                    @default("ACTIVE")
  balance           Decimal                   @default("0")
  version           Int                       @default(1)
  createdBy         String?
  frozenAt          DateTime?
  frozenBy          String?
  freezeReason      String?
  closedAt          DateTime?
  closedBy          String?
  closeReason       String?
  createdAt         DateTime                  @default(now())
  updatedAt         DateTime                  @default(now()) @updatedAt
  tenant            Tenant                    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  product           Product?                  @relation(fields: [tenantId, productId], references: [tenantId, id], onDelete: Restrict)
  entries           AccountEntry[]
  lifecycleRequests AccountLifecycleRequest[]

  @@unique([tenantId, id])
  @@index([tenantId])
  @@index([tenantId, customerId])
  @@index([tenantId, productId])
  @@index([tenantId, status])
  @@map("accounts")
}

model AccountEntry {
  id             String   @id
  tenantId       String
  accountId      String
  journalEntryId String?
  transactionId  String?
  postingKey     String
  entryType      String
  direction      String
  amount         Decimal
  currency       String
  balanceAfter   Decimal
  reference      String?
  createdBy      String
  postedAt       DateTime
  createdAt      DateTime @default(now())
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  account        Account  @relation(fields: [tenantId, accountId], references: [tenantId, id], onDelete: Cascade)

  @@unique([tenantId, id])
  @@unique([tenantId, postingKey])
  @@index([tenantId, accountId, postedAt, id])
  @@index([tenantId, journalEntryId])
  @@index([tenantId, transactionId])
  @@map("account_entries")
}

model AccountLifecycleRequest {
  id                     String    @id
  tenantId               String
  accountId              String
  transition             String
  fromStatus             String
  targetStatus           String
  expectedAccountVersion Int
  status                 String    @default("PENDING_APPROVAL")
  reason                 String
  requestedBy            String
  requestedRoles         Json
  institutionId          String
  branchId               String?
  correlationId          String
  decidedBy              String?
  decisionReason         String?
  decidedAt              DateTime?
  appliedAt              DateTime?
  failureReason          String?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @default(now()) @updatedAt
  tenant                 Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  account                Account   @relation(fields: [tenantId, accountId], references: [tenantId, id], onDelete: Cascade)

  @@unique([tenantId, id])
  @@index([tenantId, status, createdAt])
  @@index([tenantId, accountId, createdAt])
  @@map("account_lifecycle_requests")
}

model Tenant {
  id                       String                    @id
  institutionId            String?                   @unique
  name                     String?
  jurisdiction             String?
  createdAt                DateTime                  @default(now())
  updatedAt                DateTime                  @updatedAt
  accounts                 Account[]
  accountEntries           AccountEntry[]
  accountLifecycleRequests AccountLifecycleRequest[]
  financialAdjustmentRequests FinancialAdjustmentRequest[]
  products                 Product[]
  tenantConfigs            TenantConfig[]
  loans                    Loan[]
  transactions             FinancialTransaction[]
  ledgerAccounts           LedgerAccount[]
  journalEntries           JournalEntry[]
  schemas                  CustomEntitySchema[]
  workflows                WorkflowDefinition[]
  rules                    Rule[]
  auditTrail               AuditTrailEvent[]
  domainOutbox             DomainOutboxEvent[]
  domainInbox              DomainInboxEvent[]
  readProjections          ReadProjection[]
  projectionCheckpoints    ProjectionCheckpoint[]

  @@map("tenants")
}

model Product {
  id        String    @id
  tenantId  String
  type      String
  name      String
  enabled   Boolean   @default(true)
  config    Json
  createdAt DateTime  @default(now())
  updatedAt DateTime  @default(now()) @updatedAt
  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  accounts  Account[]

  @@unique([tenantId, id])
  @@index([tenantId])
  @@map("products")
}

model TenantConfig {
  id        String   @id @default(cuid())
  tenantId  String
  config    Json
  createdAt DateTime @default(now())
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("tenant_configs")
}

model Loan {
  id         String   @id
  tenantId   String
  customerId String
  productId  String
  status     String
  data       Json
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now()) @updatedAt
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, id])
  @@index([tenantId])
  @@index([tenantId, customerId])
  @@map("loans")
}

model FinancialTransaction {
  id             String    @id
  tenantId       String
  type           String
  status         String
  amount         Decimal
  currency       String
  loanId         String?
  idempotencyKey String?
  data           Json
  createdAt      DateTime  @default(now())
  postedAt       DateTime?
  adjustmentRequestId String?
  reversalOfTransactionId String?
  correctionOfTransactionId String?
  tenant         Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, id])
  @@unique([tenantId, idempotencyKey])
  @@index([tenantId])
  @@index([tenantId, loanId])
  @@index([tenantId, adjustmentRequestId])
  @@index([tenantId, reversalOfTransactionId])
  @@index([tenantId, correctionOfTransactionId])
  @@map("financial_transactions")
}

model LedgerAccount {
  id              String   @id @default(cuid())
  tenantId        String
  accountCode     String
  accountName     String
  accountClass    String
  accountSubclass String
  balanceDebit    Decimal  @default("0")
  balanceCredit   Decimal  @default("0")
  currency        String
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, accountCode])
  @@index([tenantId])
  @@map("ledger_accounts")
}

model JournalEntry {
  id            String   @id
  tenantId      String
  transactionId String
  description   String
  postedBy      String
  status        String
  entryDate     DateTime
  postingDate   DateTime
  lines         Json
  metadata      Json
  createdAt     DateTime @default(now())
  adjustmentRequestId String?
  reversalOfEntryId String?
  correctionOfEntryId String?
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, id])
  @@index([tenantId])
  @@index([tenantId, transactionId])
  @@index([tenantId, adjustmentRequestId])
  @@index([tenantId, reversalOfEntryId])
  @@index([tenantId, correctionOfEntryId])
  @@map("journal_entries")
}

model FinancialAdjustmentRequest {
  id                       String   @id
  tenantId                 String
  targetType               String
  targetId                 String
  adjustmentType           String
  status                   String   @default("PENDING_APPROVAL")
  reason                   String
  correction               Json?
  targetTransactionId      String?
  targetJournalEntryId     String
  targetLoanId             String?
  expectedLoanVersion      Int?
  requestedBy              String
  requestedRoles           Json
  institutionId            String
  branchId                 String?
  correlationId            String
  decidedBy                String?
  decisionReason           String?
  decidedAt                DateTime?
  appliedAt                DateTime?
  failureReason            String?
  reversalTransactionId    String?
  reversalJournalEntryId   String?
  replacementTransactionId String?
  replacementJournalEntryId String?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @default(now()) @updatedAt
  tenant                   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, id])
  @@index([tenantId, status, createdAt])
  @@index([tenantId, targetType, targetId, createdAt])
  @@index([tenantId, targetTransactionId])
  @@index([tenantId, targetJournalEntryId])
  @@index([tenantId, targetLoanId])
  @@map("financial_adjustment_requests")
}

model CustomEntitySchema {
  id          String   @id
  tenantId    String
  entityName  String
  displayName String
  fields      Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, id])
  @@index([tenantId])
  @@map("custom_entity_schemas")
}

model WorkflowDefinition {
  id        String   @id
  tenantId  String
  name      String
  trigger   String
  steps     Json
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, id])
  @@index([tenantId])
  @@index([tenantId, trigger])
  @@map("workflow_definitions")
}

model Rule {
  id        String   @id
  tenantId  String
  productId String
  ruleType  String
  condition String
  action    Json
  priority  Int
  enabled   Boolean  @default(true)
  appliesTo Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, id])
  @@index([tenantId])
  @@index([tenantId, productId])
  @@map("rules")
}

model AuditTrailEvent {
  id         String   @id
  tenantId   String
  action     String
  entityType String
  entityId   String
  phase      String?
  stage      String?
  result     String?
  source     String?
  actorId    String?
  actorRoles Json?
  institutionId String?
  branchId   String?
  reason     String?
  correlationId String?
  causationId String?
  approvalReference String?
  metadata   Json
  createdAt  DateTime @default(now())
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, entityType, entityId])
  @@index([tenantId, stage, createdAt])
  @@index([tenantId, correlationId])
  @@map("audit_trail_events")
}

model DomainOutboxEvent {
  eventId          String    @id
  tenantId         String
  eventType        String
  eventVersion     Int
  occurredAt       DateTime
  aggregateType    String
  aggregateId      String
  aggregateVersion Int
  correlationId    String
  causationId      String
  idempotencyKey   String?
  payload          Json
  metadata         Json
  status           String    @default("PENDING")
  attempts         Int       @default(0)
  maxAttempts      Int       @default(3)
  availableAt      DateTime  @default(now())
  lockedUntil      DateTime?
  lockedBy         String?
  publishedAt      DateTime?
  failedAt         DateTime?
  lastError        String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @default(now()) @updatedAt
  tenant           Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, idempotencyKey])
  @@index([tenantId, status, availableAt])
  @@index([tenantId, aggregateType, aggregateId])
  @@index([eventType, eventVersion])
  @@map("domain_outbox_events")
}

model DomainInboxEvent {
  id           String    @id @default(cuid())
  eventId      String
  consumerName String
  tenantId     String
  status       String
  processedAt  DateTime?
  failedAt     DateTime?
  lastError    String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @default(now()) @updatedAt
  tenant       Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, eventId, consumerName])
  @@index([tenantId, status])
  @@index([tenantId, eventId])
  @@map("domain_inbox_events")
}

model ReadProjection {
  id               String   @id @default(cuid())
  tenantId         String
  projectionName   String
  entityId         String
  entityType       String
  data             Json
  lastEventId      String
  lastEventType    String
  lastEventVersion Int
  lastOccurredAt   DateTime
  createdAt        DateTime @default(now())
  updatedAt        DateTime @default(now()) @updatedAt
  tenant           Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, projectionName, entityId])
  @@index([tenantId, projectionName])
  @@index([tenantId, entityType, entityId])
  @@index([lastEventType, lastEventVersion])
  @@map("read_projections")
}

model ProjectionCheckpoint {
  id               String    @id @default(cuid())
  tenantId         String
  projectionName   String
  lastEventId      String?
  lastEventType    String?
  lastEventVersion Int?
  lastOccurredAt   DateTime?
  eventCount       Int       @default(0)
  lagMs            BigInt    @default(0)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @default(now()) @updatedAt
  tenant           Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, projectionName])
  @@index([tenantId])
  @@map("projection_checkpoints")
}
