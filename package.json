{
  "name": "@mavula/ledger-core",
  "version": "0.1.0",
  "private": true,
  "description": "MAVULA Ledger Core - financial source of truth for ledger, lending and product configuration.",
  "author": "EstandarMustaq <estandarmustaq@mavula.io>",
  "license": "AGPL-3.0-only",
  "main": "dist/main.js",
  "scripts": {
    "prebuild": "prisma generate",
    "build": "tsc -p tsconfig.json",
    "guardian:check": "node scripts/guardian.mjs",
    "start": "node dist/main.js",
    "start:dev": "ts-node-dev --respawn --transpile-only src/main.ts",
    "check:no-console": "node scripts/check-no-console.js",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest --runInBand",
    "test:e2e": "NODE_OPTIONS=--experimental-vm-modules jest --config jest.e2e.config.js --runInBand",
    "test:integration": "NODE_OPTIONS=--experimental-vm-modules jest --testPathPattern=integration.spec.ts --runInBand",
    "test:rls": "LEDGER_CORE_RLS_TEST=true NODE_OPTIONS=--experimental-vm-modules jest --runInBand test/tenant-rls.integration.spec.ts",
    "test:all": "node scripts/check-no-console.js && NODE_OPTIONS=--experimental-vm-modules jest --runInBand && NODE_OPTIONS=--experimental-vm-modules jest --config jest.e2e.config.js --runInBand",
    "test:financial": "NODE_OPTIONS=--experimental-vm-modules jest --testPathPattern='(financial|loan|ledger|transaction|rules)' --runInBand",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate deploy",
    "prisma:dev": "prisma migrate dev",
    "database:migrate": "node scripts/migrate-database.mjs",
    "database:provision-role": "node scripts/provision-database-role.mjs",
    "prisma:studio": "prisma studio"
  },
  "dependencies": {
    "@nestjs/common": "^10.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/platform-express": "^10.0.0",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.0",
    "@prisma/client": "5.7.0",
    "class-validator": "^0.14.0",
    "class-transformer": "^0.5.1",
    "jose": "6.2.3",
    "prom-client": "^14.0.0",
    "bullmq": "^5.0.0",
    "ioredis": "^5.3.2",
    "supertest": "^6.3.3",
    "decimal.js": "^10.4.0"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "ts-node-dev": "^2.0.0",
    "jest": "^29.0.0",
    "ts-jest": "^29.0.0",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.0.0",
    "@nestjs/testing": "^10.0.0",
    "@types/supertest": "^6.0.2",
    "prisma": "5.7.0"
  },
  "engines": {
    "node": "22.22.3",
    "pnpm": "10.33.0"
  }
}
